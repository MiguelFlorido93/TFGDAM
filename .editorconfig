root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,css,html,sql}]
indent_style = space
indent_size = 4

[*.{json,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.java]
indent_style = space
indent_size = 4

[*.bat]
end_of_line = crlf
