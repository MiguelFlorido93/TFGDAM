{
  "name": "stockly-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Configuración de tooling (ESLint + Prettier) para todo el proyecto Stockly TFG DAM",
  "scripts": {
    "lint":         "eslint backend frontend",
    "lint:fix":     "eslint backend frontend --fix",
    "format":       "prettier --write \"backend/**/*.js\" \"frontend/**/*.js\"",
    "format:check": "prettier --check \"backend/**/*.js\" \"frontend/**/*.js\"",
    "format:all":   "prettier --write \"backend/**/*.{js,json}\" \"frontend/**/*.{js,json,css,html}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3"
  }
}
