  <!-- ===================================================
       PÁGINA 2: Diagrama de Despliegue
       =================================================== -->
  <diagram id="deploy" name="Despliegue (Railway)">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ── NUBE RAILWAY ── -->
        <mxCell id="railway_cloud" value="☁  Railway (Cloud)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#7e57c2;fontSize=15;fontStyle=1;verticalAlign=top;opacity=60;" vertex="1" parent="1">
          <mxGeometry x="280" y="30" width="680" height="500" as="geometry"/>
        </mxCell>

        <!-- Backend service -->
        <mxCell id="deploy_backend" value="&lt;b&gt;Servicio: Backend&lt;/b&gt;&lt;br/&gt;Node.js 24 · Express 4&lt;br/&gt;Nixpacks (npm ci --omit=dev)&lt;br/&gt;node server.js&lt;br/&gt;trust proxy · 0.0.0.0:$PORT&lt;br/&gt;restart: ON_FAILURE (max 5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="100" width="280" height="150" as="geometry"/>
        </mxCell>

        <!-- MySQL service -->
        <mxCell id="deploy_mysql" value="&lt;b&gt;Plugin: MySQL 8&lt;/b&gt;&lt;br/&gt;Servicio gestionado&lt;br/&gt;MYSQL_URL inyectada&lt;br/&gt;Backups diarios&lt;br/&gt;Persistencia entre deploys" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="180" height="150" as="geometry"/>
        </mxCell>

        <!-- Env vars -->
        <mxCell id="env_vars" value="&lt;b&gt;Variables de entorno&lt;/b&gt;&lt;br/&gt;NODE_ENV=production&lt;br/&gt;JWT_SECRET (≥256 bits)&lt;br/&gt;JWT_EXPIRES_IN=8h&lt;br/&gt;CORS_ORIGIN&lt;br/&gt;MYSQL_URL (referencia plugin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9c27b0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="290" width="220" height="130" as="geometry"/>
        </mxCell>

        <!-- Health check -->
        <mxCell id="health_check" value="&lt;b&gt;Health Check&lt;/b&gt;&lt;br/&gt;GET /api/health&lt;br/&gt;{ok:true, db:true}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#9c27b0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="575" y="290" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Public URL -->
        <mxCell id="public_url" value="&lt;b&gt;URL pública (HTTPS automático)&lt;/b&gt;&lt;br/&gt;https://tfgdam-production.up.railway.app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="440" width="550" height="60" as="geometry"/>
        </mxCell>

        <!-- ── GITHUB ── -->
        <mxCell id="github" value="&lt;b&gt;GitHub&lt;/b&gt;&lt;br/&gt;husslesnake/TFGDAM&lt;br/&gt;rama: main&lt;br/&gt;trunk-based (feat/fix/docs/chore)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="200" height="110" as="geometry"/>
        </mxCell>

        <!-- ── CLIENTES ── -->
        <mxCell id="browser_client" value="&lt;b&gt;Navegador&lt;/b&gt;&lt;br/&gt;PWA instalable&lt;br/&gt;Chrome / Firefox / Edge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="30" width="180" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="phone_client" value="&lt;b&gt;Android&lt;/b&gt;&lt;br/&gt;App nativa (Kotlin)&lt;br/&gt;operario de almacén" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="390" width="180" height="90" as="geometry"/>
        </mxCell>

        <!-- ── FLECHAS ── -->
        <!-- GitHub → Railway (webhook auto-deploy) -->
        <mxCell id="arr_gh_rw" value="git push main&lt;br/&gt;→ auto-deploy (webhook)" style="endArrow=block;endFill=1;html=1;strokeColor=#7e57c2;fontColor=#7e57c2;fontStyle=1;fontSize=10;" edge="1" source="github" target="deploy_backend" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Backend ↔ MySQL -->
        <mxCell id="arr_be_db" value="MYSQL_URL · pool(10)&lt;br/&gt;prepared statements" style="endArrow=block;endFill=1;startArrow=block;startFill=0;html=1;strokeColor=#d6b656;fontColor=#a07000;fontStyle=1;fontSize=10;" edge="1" source="deploy_backend" target="deploy_mysql" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Browser → Public URL -->
        <mxCell id="arr_br_url" value="HTTPS · JWT" style="endArrow=block;endFill=1;startArrow=block;startFill=0;html=1;strokeColor=#388e3c;fontColor=#388e3c;fontStyle=1;fontSize=10;" edge="1" source="browser_client" target="public_url" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Android → Public URL -->
        <mxCell id="arr_and_url" value="HTTPS · JWT" style="endArrow=block;endFill=1;startArrow=block;startFill=0;html=1;strokeColor=#388e3c;fontColor=#388e3c;fontStyle=1;fontSize=10;" edge="1" source="phone_client" target="public_url" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Env vars → Backend (configuran) -->
        <mxCell id="arr_env_be" value="configura" style="endArrow=open;endFill=0;html=1;strokeColor=#9c27b0;fontColor=#9c27b0;fontSize=9;dashed=1;" edge="1" source="env_vars" target="deploy_backend" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

